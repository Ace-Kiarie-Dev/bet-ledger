rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSettled(betData) {
      return betData.outcome == 'win' || betData.outcome == 'loss';
    }

    // Mirrors LOCKED_FIELDS in app/utils/storage.js: once a bet is settled
    // (win/loss), outcome/stake/odds/market/selection can never change again.
    function touchesLockedFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['outcome', 'stake', 'odds', 'market', 'selection']);
    }

    match /users/{userId} {

      match /profile/{profileId} {
        allow read, write: if isOwner(userId);
      }

      match /bets/{betId} {
        allow read, create: if isOwner(userId);

        allow update: if isOwner(userId) &&
          (!isSettled(resource.data) || !touchesLockedFields());

        // Delete-lock relaxed 2026-07-15 (superseding the original comment
        // here) to allow client-side account deletion without the Blaze
        // plan — see docs/sessions/DECISIONS.md. The update lock above is
        // untouched: a settled bet still can't be edited, only removed
        // entirely as part of deleting the whole account. Re-tighten to
        // `if isOwner(userId) && !isSettled(resource.data)` before any
        // cross-user feature (leaderboard, verified badges) ships.
        allow delete: if isOwner(userId);
      }

      // Not yet written by the client anywhere (see app/utils/storage.js —
      // getStats has no matching setter). Reserved for a future server-side
      // writer (Cloud Function) once that's built.
      match /stats/{statId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // leaderboard/cleanStreak/{userId}, leaderboard/budgetStreak/{userId}.
    // Readable so a future leaderboard UI can show other users' rows, but
    // writes stay closed until a write-strategy is decided — see
    // docs/sessions/DECISIONS.md ("Leaderboard: no cross-user data until
    // Firestore rules + write-strategy are decided").
    match /leaderboard/{board}/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
